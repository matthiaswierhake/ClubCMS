{
  "name": "wpclubcms/clubcms",
  "description": "ClubCMS WordPress plugin",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=8.2"
  },
  "autoload": {
    "psr-4": {
      "ClubCMS\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ClubCMS\\Tests\\": "tests/"
    },
    "files": [
      "src/Support/WordPressStubs.php"
    ]
  },
  "scripts": {
    "test": [
      "php tests/run.php"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "license": "proprietary"
}
